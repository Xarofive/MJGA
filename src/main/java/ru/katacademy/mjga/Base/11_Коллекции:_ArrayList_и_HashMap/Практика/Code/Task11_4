public static void processInventory(BufferedReader reader, PrintWriter writer) throws IOException {
    HashMap<String, HashMap<String, Integer>> inventory = new HashMap<>();
    int n = Integer.parseInt(reader.readLine());

    for (int i = 0; i < n; i++) {
        String line = reader.readLine();
        String[] parts = line.split("\\s+");
        String command = parts[0];

        if ("ADD".equals(command)) {
            String category = parts[1];
            String item = parts[2];
            int price = Integer.parseInt(parts[3]);
            int quantity = Integer.parseInt(parts[4]);
            HashMap<String, Integer> items = inventory.get(category);
            if (items == null) {
                items = new HashMap<>();
                inventory.put(category, items);
            }
            Integer current = items.get(item);
            if (current == null) {
                current = 0;
            }
            items.put(item, current + price * quantity);
        } else if ("DELETE".equals(command)) {
            String category = parts[1];
            String item = parts[2];
            HashMap<String, Integer> items = inventory.get(category);
            boolean deleted = false;
            if (items != null && items.remove(item) != null) {
                deleted = true;
                if (items.isEmpty()) {
                    inventory.remove(category);
                }
            }
            writer.println(deleted ? "OK" : "NOT FOUND");
        } else if ("TOTAL".equals(command)) {
            if (!inventory.containsKey(parts[1])) {
                writer.println("NOT FOUND");
            } else {
                writer.println(totalByCategory(inventory, parts[1]));
            }
        } else if ("SUMMARY".equals(command)) {
            ArrayList<String> categories = new ArrayList<>(inventory.keySet());
            Collections.sort(categories);
            if (categories.isEmpty()) {
                writer.println("EMPTY");
            } else {
                for (String category : categories) {
                    writer.println(category + " " + totalByCategory(inventory, category));
                }
            }
        }
    }
}

private static int totalByCategory(HashMap<String, HashMap<String, Integer>> inventory, String category) {
    HashMap<String, Integer> items = inventory.get(category);
    if (items == null) {
        return 0;
    }

    int sum = 0;
    for (int value : items.values()) {
        sum += value;
    }
    return sum;
}
