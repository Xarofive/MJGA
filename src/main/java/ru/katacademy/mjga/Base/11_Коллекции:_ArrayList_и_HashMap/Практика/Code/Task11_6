// ожидаемый код решения

public static ArrayList<Integer> filterAtLeast(int[] values, int limit) {
    ArrayList<Integer> result = new ArrayList<>();
    for (int value : values) {
        if (value >= limit) {
            result.add(value);
        }
    }
    return result;
}
