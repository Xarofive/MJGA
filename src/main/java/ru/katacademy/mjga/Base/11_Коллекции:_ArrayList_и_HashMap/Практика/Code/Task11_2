import org.junit.FixMethodOrder;
import org.junit.Test;
import org.junit.runners.MethodSorters;

import java.util.ArrayList;
import java.util.Arrays;
import java.util.HashMap;

@FixMethodOrder(MethodSorters.NAME_ASCENDING)
public class Task11_2 {
    @Test
    public void test1_keepsFirstOccurrences() {
        check(new int[]{1, 2, 1, 3, 2}, new ArrayList<>(Arrays.asList(1, 2, 3)));
        check(new int[]{5, 5, 5}, new ArrayList<>(Arrays.asList(5)));
    }

    @Test
    public void test2_handlesEmptyAndNegativeValues() {
        check(new int[0], new ArrayList<Integer>());
        check(new int[]{-1, 0, -1, 2}, new ArrayList<>(Arrays.asList(-1, 0, 2)));
    }

    private void check(int[] values, ArrayList<Integer> expected) {
        ArrayList<Integer> actual = uniqueInOrder(values);
        if (!expected.equals(actual)) {
            failWithoutStackTrace("Для массива " + Arrays.toString(values) + " ожидался список " +
                    expected + ", но получен " + actual + ".");
        }
    }

    private void failWithoutStackTrace(String message) {
        AssertionError error = new AssertionError(message);
        error.setStackTrace(new StackTraceElement[0]);
        throw error;
    }

