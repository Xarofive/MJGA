// ожидаемый код решения

public static ArrayList<Integer> uniqueInOrder(int[] values) {
    HashMap<Integer, Boolean> seen = new HashMap<>();
    ArrayList<Integer> result = new ArrayList<>();

    for (int value : values) {
        if (!seen.containsKey(value)) {
            seen.put(value, true);
            result.add(value);
        }
    }

    return result;
}
