// ожидаемый код решения

public static void processPhonebook(BufferedReader reader, PrintWriter writer) throws IOException {
    HashMap<String, String> phonebook = new HashMap<>();
    int q = Integer.parseInt(reader.readLine());

    for (int i = 0; i < q; i++) {
        String line = reader.readLine();
        String[] parts = line.split("\\s+");
        String command = parts[0];

        if ("PUT".equals(command)) {
            phonebook.put(parts[1], parts[2]);
        } else if ("GET".equals(command)) {
            String phone = phonebook.get(parts[1]);
            if (phone == null) {
                writer.println("NOT FOUND");
            } else {
                writer.println(phone);
            }
        } else if ("COUNT".equals(command)) {
            writer.println(phonebook.size());
        } else if ("DEL".equals(command)) {
            if (phonebook.remove(parts[1]) == null) {
                writer.println("NOT FOUND");
            } else {
                writer.println("OK");
            }
        }
    }
}
