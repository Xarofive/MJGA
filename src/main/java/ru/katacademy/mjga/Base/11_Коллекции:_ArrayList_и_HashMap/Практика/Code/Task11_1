@FixMethodOrder(MethodSorters.NAME_ASCENDING)
public class Task11_1 {
    @Test
    public void test1_processesPhonebookCommands() throws IOException {
        String input = "7\nPUT Alice 123456\nGET Alice\nGET Bob\nPUT Bob 555\nCOUNT\nDEL Bob\nCOUNT\n";
        String expected = "123456\nNOT FOUND\n2\nOK\n1\n";
        check(input, expected);
    }

    @Test
    public void test2_updatesAndDeletesContacts() throws IOException {
        String input = "6\nPUT Ann 100\nPUT Ann 200\nGET Ann\nDEL Ann\nGET Ann\nCOUNT\n";
        String expected = "200\nOK\nNOT FOUND\n0\n";
        check(input, expected);
    }

    private void check(String input, String expected) throws IOException {
        StringWriter output = new StringWriter();
        processPhonebook(new BufferedReader(new StringReader(input)), new PrintWriter(output, true));
        String actual = output.toString().replace("\r\n", "\n");
        if (!expected.equals(actual)) {
            failWithoutStackTrace("Ожидался вывод:\n" + expected + "Но получен:\n" + actual);
        }
    }

    private void failWithoutStackTrace(String message) {
        AssertionError error = new AssertionError(message);
        error.setStackTrace(new StackTraceElement[0]);
        throw error;
    }

