// ожидаемый код решения

class Counter {
    int value;

    void increment() {
        value++;
    }

    void add(int amount) {
        value += amount;
    }

    String status() {
        return "Counter: " + value;
    }

    static boolean sameObject(Counter first, Counter second) {
        return first == second;
    }
}
