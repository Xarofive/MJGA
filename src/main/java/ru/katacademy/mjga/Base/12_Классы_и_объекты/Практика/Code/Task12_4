// ожидаемый код решения

class Product {
    String name;
    int price;
    int quantity;

    int totalPrice() {
        return price * quantity;
    }

    void add(int amount) {
        quantity += amount;
    }

    boolean sell(int amount) {
        if (amount > quantity) {
            return false;
        }
        quantity -= amount;
        return true;
    }

    String getLabel() {
        return name + " (" + quantity + " pcs)";
    }
}
