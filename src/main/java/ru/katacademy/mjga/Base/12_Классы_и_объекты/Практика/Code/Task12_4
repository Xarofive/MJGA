import org.junit.FixMethodOrder;
import org.junit.Test;
import org.junit.runners.MethodSorters;

@FixMethodOrder(MethodSorters.NAME_ASCENDING)
public class Task12_4 {
    @Test
    public void test1_countsProductTotalAndLabel() {
        Product product = new Product();
        product.name = "Notebook";
        product.price = 50;
        product.quantity = 2;

        check(100, product.totalPrice());
        check("Notebook (2 pcs)", product.getLabel());
    }

    @Test
    public void test2_addsAndSellsProducts() {
        Product product = new Product();
        product.name = "Pen";
        product.price = 10;
        product.quantity = 3;

        product.add(2);
        if (!product.sell(4)) {
            failWithoutStackTrace("Продажа 4 товаров при количестве 5 должна вернуть true.");
        }
        check(1, product.quantity);
        if (product.sell(2)) {
            failWithoutStackTrace("Продажа количества больше остатка должна вернуть false.");
        }
        check("Pen (1 pcs)", product.getLabel());
    }

    private void check(int expected, int actual) {
        if (expected != actual) {
            failWithoutStackTrace("Ожидалось значение " + expected + ", но получено " + actual + ".");
        }
    }

    private void check(String expected, String actual) {
        if (!expected.equals(actual)) {
            failWithoutStackTrace("Ожидалась строка \"" + expected + "\", но получена \"" + actual + "\".");
        }
    }

    private void failWithoutStackTrace(String message) {
        AssertionError error = new AssertionError(message);
        error.setStackTrace(new StackTraceElement[0]);
        throw error;
    }
}

