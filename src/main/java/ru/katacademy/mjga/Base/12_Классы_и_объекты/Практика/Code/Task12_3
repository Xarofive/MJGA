// ожидаемый код решения

class BankAccount {
    String owner;
    int balance;

    void deposit(int amount) {
        balance += amount;
    }

    boolean withdraw(int amount) {
        if (amount > balance) {
            return false;
        }
        balance -= amount;
        return true;
    }

    int getBalance() {
        return balance;
    }

    String getInfo() {
        return owner + ": " + balance;
    }
}
