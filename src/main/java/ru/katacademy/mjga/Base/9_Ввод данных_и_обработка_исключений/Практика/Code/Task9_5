}

// ожидаемый код решения

static int sumInts(BufferedReader reader) throws IOException {
    if (reader == null) {
        throw new IllegalArgumentException("reader is null");
    }

    int sum = 0;
    boolean foundNumber = false;
    String line;
    while ((line = reader.readLine()) != null) {
        String cleaned = line.trim();
        if (cleaned.isEmpty()) {
            continue;
        }

        try {
            sum += Integer.parseInt(cleaned);
            foundNumber = true;
        } catch (NumberFormatException e) {
            throw new IllegalArgumentException("invalid number: " + cleaned);
        }
    }

    if (!foundNumber) {
        throw new IllegalArgumentException("no numbers");
    }
    return sum;
}
