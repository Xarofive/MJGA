@FixMethodOrder(MethodSorters.NAME_ASCENDING)
public class Task10_8 {
    @Test
    public void test1_returnsKnownAccessLevels() {
        check("admin", "all");
        check("Administrator", "all");
        check("Moderator", "write");
        check(" guest ", "read");
        check("blocked", "none");
    }

    @Test
    public void test2_handlesUnknownRoles() {
        check("owner", "unknown");
        check("", "unknown");
    }

    private void check(String role, String expected) {
        String actual = accessLevel(role);
        if (!expected.equals(actual)) {
            failWithoutStackTrace("Для роли \"" + role + "\" ожидалось \"" + expected +
                    "\", но метод вернул \"" + actual + "\".");
        }
    }

    private void failWithoutStackTrace(String message) {
        AssertionError error = new AssertionError(message);
        error.setStackTrace(new StackTraceElement[0]);
        throw error;
    }

