import org.junit.FixMethodOrder;
import org.junit.Test;
import org.junit.runners.MethodSorters;

@FixMethodOrder(MethodSorters.NAME_ASCENDING)
public class Task10_6 {
    @Test
    public void test1_parsesByteValues() {
        check("0", "OK: 0");
        check("255", "OK: 255");
        check(" 7 ", "OK: 7");
    }

    @Test
    public void test2_returnsErrors() {
        check("256", "RANGE ERROR");
        check("-1", "RANGE ERROR");
        check("12px", "FORMAT ERROR");
    }

    private void check(String input, String expected) {
        String actual = parseByteStatus(input);
        if (!expected.equals(actual)) {
            failWithoutStackTrace("Для ввода \"" + input + "\" ожидалось \"" + expected +
                    "\", но метод вернул \"" + actual + "\".");
        }
    }

    private void failWithoutStackTrace(String message) {
        AssertionError error = new AssertionError(message);
        error.setStackTrace(new StackTraceElement[0]);
        throw error;
    }

