// ожидаемый код решения

public static String parseByteStatus(String input) {
    int status;
    int value = 0;

    try {
        value = Integer.parseInt(input.trim());
        if (value < 0 || value > 255) {
            status = 1;
        } else {
            status = 0;
        }
    } catch (NumberFormatException e) {
        status = 2;
    }

    return switch (status) {
        case 0 -> "OK: " + value;
        case 1 -> "RANGE ERROR";
        default -> "FORMAT ERROR";
    };
}
