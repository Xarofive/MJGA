    //END_STUDENT_PLACEHOLDER//
}

// ожидаемый код решения

static String hydrationReminder(int temp, int minutesOutside) {
    if (temp < -30 || minutesOutside < 0) {
        return "invalid";
    }
    if (temp > 30 || minutesOutside > 90) {
        return "bring bottle";
    }
    if ((temp >= 20 && temp <= 30) || (minutesOutside >= 30 && minutesOutside <= 90)) {
        return "optional";
    }
    return "no need";
}
