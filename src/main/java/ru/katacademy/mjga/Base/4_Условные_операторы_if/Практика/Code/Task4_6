}

// ожидаемый код решения

static String streamQuality(int speed, boolean congested) {
    if (speed <= 0) {
        return "invalid";
    }
    if (congested) {
        if (speed < 15) {
            return "low";
        }
        return "medium";
    }
    if (speed < 8) {
        return "low";
    } else if (speed < 15) {
        return "medium";
    } else if (speed < 25) {
        return "high";
    } else {
        return "ultra";
    }
}
