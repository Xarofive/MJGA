// ожидаемый код решения

static int sumSkipMultiples(int limit, int skip) {
    if (limit <= 0 || skip == 1) {
        return 0;
    }
    int sum = 0;
    for (int i = 1; i <= limit; i++) {
        if (i % skip == 0) {
            continue;
        }
        sum += i;
    }
    return sum;
}
