}

// ожидаемый код решения

static int[] cloneArray(int[] src) {
    if (src == null) {
        return null;
    }
    int[] copy = new int[src.length];
    for (int i = 0; i < src.length; i++) {
        copy[i] = src[i];
    }
    return copy;
}
