    //END_STUDENT_PLACEHOLDER//
}

// ожидаемый код решения

static int[] buildCountdown(int start) {
    if (start < 0) {
        return new int[0];
    }
    int[] result = new int[start + 1];
    for (int value = start, index = 0; value >= 0; value--, index++) {
        result[index] = value;
    }
    return result;
}
