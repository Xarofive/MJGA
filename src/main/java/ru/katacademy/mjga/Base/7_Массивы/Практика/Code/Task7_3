import org.junit.FixMethodOrder;
import org.junit.Test;
import org.junit.runners.MethodSorters;

import java.io.ByteArrayOutputStream;
import java.io.PrintStream;

@FixMethodOrder(MethodSorters.NAME_ASCENDING)
public class Task7_3 {
    private static final String EXPECTED_OUTPUT = "3 3\n";

    @Test
    public void test1_printsExactText() {
        String actualOutput = runAndReadOutput();
        if (!EXPECTED_OUTPUT.equals(actualOutput)) {
            failWithoutStackTrace("Тест не пройден. Ожидался вывод \"3 3\\n\", получен \"" + actualOutput.replace("\n", "\\n") + "\".");
        }
    }

    private String runAndReadOutput() {
        PrintStream originalOut = System.out;
        ByteArrayOutputStream output = new ByteArrayOutputStream();
        try {
            System.setOut(new PrintStream(output));
            runSolution();
            return output.toString().replaceAll("\r", "");
        } catch (Throwable exception) {
            failWithoutStackTrace("Во время запуска решения возникла ошибка: " + exception);
            return "";
        } finally {
            System.setOut(originalOut);
        }
    }

    private void failWithoutStackTrace(String message) {
        AssertionError error = new AssertionError(message);
        error.setStackTrace(new StackTraceElement[0]);
        throw error;
    }

