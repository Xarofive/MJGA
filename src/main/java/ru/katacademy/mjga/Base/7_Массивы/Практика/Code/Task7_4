import org.junit.FixMethodOrder;
import org.junit.Test;
import org.junit.runners.MethodSorters;

import java.util.Arrays;

@FixMethodOrder(MethodSorters.NAME_ASCENDING)
public class Task7_4 {
    @Test
    public void test1_filtersPositiveValues() {
        check(new int[]{-2, -1, 0, 3, 5, -4}, new int[]{3, 5});
        check(new int[]{0, -7}, new int[]{});
        check(new int[]{1, 2, 3}, new int[]{1, 2, 3});
    }

    private void check(int[] source, int[] expected) {
        int[] original = Arrays.copyOf(source, source.length);
        int[] actual = filterPositive(source);
        if (!Arrays.equals(expected, actual)) {
            failWithoutStackTrace("Тест не пройден: ожидался массив " + Arrays.toString(expected) +
                    ", получен " + Arrays.toString(actual) + ".");
        }
        if (!Arrays.equals(original, source)) {
            failWithoutStackTrace("Тест не пройден: исходный массив был изменён.");
        }
    }

    private void failWithoutStackTrace(String message) {
        AssertionError error = new AssertionError(message);
        error.setStackTrace(new StackTraceElement[0]);
        throw error;
    }

