}

// ожидаемый код решения

static int[] filterPositive(int[] src) {
    int count = 0;
    for (int value : src) {
        if (value > 0) {
            count++;
        }
    }
    int[] result = new int[count];
    int index = 0;
    for (int value : src) {
        if (value > 0) {
            result[index] = value;
            index++;
        }
    }
    return result;
}
