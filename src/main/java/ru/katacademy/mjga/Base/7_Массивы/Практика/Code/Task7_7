// ожидаемый код решения

static int[] removeRange(int[] array, int from, int to) {
    if (from >= to || from < 0 || to > array.length) {
        int[] copy = new int[array.length];
        for (int i = 0; i < array.length; i++) {
            copy[i] = array[i];
        }
        return copy;
    }
    int[] result = new int[array.length - (to - from)];
    int index = 0;
    for (int i = 0; i < array.length; i++) {
        if (i >= from && i < to) {
            continue;
        }
        result[index] = array[i];
        index++;
    }
    return result;
}
