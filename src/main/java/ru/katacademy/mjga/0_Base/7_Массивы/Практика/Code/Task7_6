import org.junit.FixMethodOrder;
import org.junit.Test;
import org.junit.runners.MethodSorters;

import java.util.Arrays;

@FixMethodOrder(MethodSorters.NAME_ASCENDING)
public class Task7_6 {
    @Test
    public void test1_mergesArrays() {
        check(new int[]{1, 2}, new int[]{3, 4, 5}, new int[]{1, 2, 3, 4, 5});
        check(new int[]{}, new int[]{1}, new int[]{1});
        check(new int[]{10}, new int[]{}, new int[]{10});
    }

    private void check(int[] a, int[] b, int[] expected) {
        int[] originalA = Arrays.copyOf(a, a.length);
        int[] originalB = Arrays.copyOf(b, b.length);
        int[] actual = mergeArrays(a, b);
        if (!Arrays.equals(expected, actual)) {
            failWithoutStackTrace("Тест не пройден: ожидался массив " + Arrays.toString(expected) +
                    ", получен " + Arrays.toString(actual) + ".");
        }
        if (!Arrays.equals(originalA, a) || !Arrays.equals(originalB, b)) {
            failWithoutStackTrace("Тест не пройден: исходные массивы изменять нельзя.");
        }
        if (actual == a || actual == b) {
            failWithoutStackTrace("Тест не пройден: нужно вернуть новый массив.");
        }
    }

    private void failWithoutStackTrace(String message) {
        AssertionError error = new AssertionError(message);
        error.setStackTrace(new StackTraceElement[0]);
        throw error;
    }

