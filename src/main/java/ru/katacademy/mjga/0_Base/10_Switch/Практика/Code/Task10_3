public static String countVowelsAndConsonants(String text) {
    int vowels = 0;
    int consonants = 0;

    for (int i = 0; i < text.length(); i++) {
        char ch = Character.toLowerCase(text.charAt(i));
        switch (ch) {
            case 'a', 'e', 'i', 'o', 'u' -> vowels++;
            default -> {
                if (ch >= 'a' && ch <= 'z') {
                    consonants++;
                }
            }
        }
    }

    return vowels + " " + consonants;
}
