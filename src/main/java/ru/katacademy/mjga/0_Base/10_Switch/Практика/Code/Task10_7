@FixMethodOrder(MethodSorters.NAME_ASCENDING)
public class Task10_7 {
    @Test
    public void test1_processesCommands() throws IOException {
        String input = "upper hello\nlower JAVA\nlen test\n?\nunknown data\nquit\n";
        String expected = "HELLO\njava\n4\ncommands: upper, lower, trim, len, help, quit\nUNKNOWN COMMAND\nbye\n";
        check(input, expected);
    }

    @Test
    public void test2_preservesTextAfterCommand() throws IOException {
        String input = "trim   hello world  \nupper java base\nexit\n";
        String expected = "hello world\nJAVA BASE\nbye\n";
        check(input, expected);
    }

    private void check(String input, String expected) throws IOException {
        StringWriter output = new StringWriter();
        processTextCommands(new BufferedReader(new StringReader(input)), new PrintWriter(output, true));
        String actual = output.toString().replace("\r\n", "\n");
        if (!expected.equals(actual)) {
            failWithoutStackTrace("Ожидался вывод:\n" + expected + "Но получен:\n" + actual);
        }
    }

    private void failWithoutStackTrace(String message) {
        AssertionError error = new AssertionError(message);
        error.setStackTrace(new StackTraceElement[0]);
        throw error;
    }

