// ожидаемый код решения

public static void processTextCommands(BufferedReader reader, PrintWriter writer) throws IOException {
    String line;
    while ((line = reader.readLine()) != null) {
        String command;
        String text;
        int spaceIndex = line.indexOf(' ');
        if (spaceIndex == -1) {
            command = line.trim().toLowerCase();
            text = "";
        } else {
            command = line.substring(0, spaceIndex).trim().toLowerCase();
            text = line.substring(spaceIndex + 1);
        }

        switch (command) {
            case "upper" -> writer.println(text.toUpperCase());
            case "lower" -> writer.println(text.toLowerCase());
            case "trim" -> writer.println(text.trim());
            case "len" -> writer.println(text.length());
            case "help", "?" -> writer.println("commands: upper, lower, trim, len, help, quit");
            case "quit", "exit", "q" -> {
                writer.println("bye");
                return;
            }
            default -> writer.println("UNKNOWN COMMAND");
        }
    }
}
