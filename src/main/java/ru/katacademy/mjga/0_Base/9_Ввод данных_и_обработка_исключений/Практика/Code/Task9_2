// ожидаемый код решения

static int[] parseCsvInts(String input) {
    if (input == null) {
        throw new IllegalArgumentException("input is null");
    }
    if (input.trim().isEmpty()) {
        throw new IllegalArgumentException("empty input");
    }

    String[] parts = input.split(",");
    int[] result = new int[parts.length];
    for (int i = 0; i < parts.length; i++) {
        String cleaned = parts[i].trim();
        if (cleaned.isEmpty()) {
            throw new IllegalArgumentException("empty element at index " + i);
        }

        try {
            result[i] = Integer.parseInt(cleaned);
        } catch (NumberFormatException e) {
            throw new IllegalArgumentException("invalid element at index " + i + ": " + cleaned);
        }
    }

    return result;
}
