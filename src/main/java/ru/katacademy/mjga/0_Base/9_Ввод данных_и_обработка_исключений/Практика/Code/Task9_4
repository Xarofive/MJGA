}

// ожидаемый код решения

static String[] readNLines(BufferedReader reader, int n) throws IOException {
    if (reader == null) {
        throw new IllegalArgumentException("reader is null");
    }
    if (n < 0) {
        throw new IllegalArgumentException("negative count");
    }

    String[] result = new String[n];
    int count = 0;
    String line;
    while (count < n && (line = reader.readLine()) != null) {
        String cleaned = line.trim();
        if (cleaned.isEmpty()) {
            continue;
        }
        result[count] = cleaned;
        count++;
    }

    if (count < n) {
        throw new IllegalArgumentException("need " + n + " got " + count);
    }
    return result;
}
