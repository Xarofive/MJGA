// ожидаемый код решения

static String normalizeSpacesManual(String s) {
    StringBuilder builder = new StringBuilder();
    boolean needSpace = false;
    for (int i = 0; i < s.length(); i++) {
        char ch = s.charAt(i);
        if (Character.isWhitespace(ch)) {
            if (builder.length() > 0) {
                needSpace = true;
            }
        } else {
            if (needSpace) {
                builder.append(' ');
                needSpace = false;
            }
            builder.append(ch);
        }
    }
    return builder.toString();
}
