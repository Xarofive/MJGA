        check("  hello   world  ", "hello world");
        check("\tJava\nBase\t", "Java Base");
        check("", "");
        check("   ", "");
    }

    private void check(String s, String expected) {
        String actual = normalizeSpacesManual(s);
        if (!expected.equals(actual)) {
            failWithoutStackTrace("Тест не пройден: normalizeSpacesManual должен вернуть \"" + expected +
                    "\", но вернул \"" + actual + "\".");
        }
    }

    private void failWithoutStackTrace(String message) {
        AssertionError error = new AssertionError(message);
        error.setStackTrace(new StackTraceElement[0]);
        throw error;
    }

