}

// ожидаемый код решения

static String joinNumbers(int[] nums) {
    StringBuilder builder = new StringBuilder();
    for (int i = 0; i < nums.length; i++) {
        if (i > 0) {
            builder.append(',');
        }
        builder.append(nums[i]);
    }
    return builder.toString();
}
