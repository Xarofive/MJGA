// ожидаемый код решения

static String substringCodePoints(String s, int start, int length) {
    if (length == 0) {
        return "";
    }
    int total = s.codePointCount(0, s.length());
    int end = start + length;
    if (end > total) {
        end = total;
    }
    int startIndex = s.offsetByCodePoints(0, start);
    int endIndex = s.offsetByCodePoints(0, end);
    return s.substring(startIndex, endIndex);
}
