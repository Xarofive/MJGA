public static ArrayList<String> frequencyReport(String[] categories) {
    if (categories.length == 0) {
        return new ArrayList<>(Arrays.asList("EMPTY"));
    }

    HashMap<String, Integer> counts = new HashMap<>();
    for (String category : categories) {
        Integer count = counts.get(category);
        if (count == null) {
            counts.put(category, 1);
        } else {
            counts.put(category, count + 1);
        }
    }

    ArrayList<String> names = new ArrayList<>(counts.keySet());
    Collections.sort(names);

    ArrayList<String> result = new ArrayList<>();
    for (String name : names) {
        result.add(name + " " + counts.get(name));
    }
    return result;
}
