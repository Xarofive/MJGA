import org.junit.FixMethodOrder;
import org.junit.Test;
import org.junit.runners.MethodSorters;

@FixMethodOrder(MethodSorters.NAME_ASCENDING)
public class Task5_1 {

    @Test
    public void test1_returnsExpectedValues() {
        check(5, 15);
        check(10, 55);
        check(1, 1);
        check(0, 0);
        check(-3, 0);
    }

    private void check(int n, int expected) {
        int actual = sumToN(n);
        if (actual != expected) {
            failWithoutStackTrace("Тест не пройден: sumToN(" + String.valueOf(n) + ") должен вернуть " + expected + ", но вернул " + actual + ".");
        }
    }

    private void failWithoutStackTrace(String message) {
        AssertionError error = new AssertionError(message);
        error.setStackTrace(new StackTraceElement[0]);
        throw error;
    }

    //START_STUDENT_PLACEHOLDER//
    // Твой код
    //END_STUDENT_PLACEHOLDER//
}

// ожидаемый код решения

static int sumToN(int n) {
    int sum = 0;
    for (int i = 1; i <= n; i++) {
        sum += i;
    }
    return sum;
}
