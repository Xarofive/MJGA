class Student {
    String name;
    int age;
    double averageGrade;

    String getCard() {
        return "Student: " + name + ", age: " + age + ", grade: " + averageGrade;
    }

    static String getCardOrDefault(Student student) {
        if (student == null) {
            return "No student";
        }
        return student.getCard();
    }
}
