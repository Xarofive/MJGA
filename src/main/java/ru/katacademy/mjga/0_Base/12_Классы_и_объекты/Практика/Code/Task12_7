// ожидаемый код решения

class BankAccount {
    String owner;
    int balance;

    void deposit(int amount) {
        balance += amount;
    }

    boolean withdraw(int amount) {
        if (amount > balance) {
            return false;
        }
        balance -= amount;
        return true;
    }

    String getInfo() {
        return owner + ": " + balance;
    }

    static boolean transfer(BankAccount from, BankAccount to, int amount) {
        if (!from.withdraw(amount)) {
            return false;
        }
        to.deposit(amount);
        return true;
    }
}
