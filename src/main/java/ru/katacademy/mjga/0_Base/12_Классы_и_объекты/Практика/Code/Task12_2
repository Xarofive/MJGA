// ожидаемый код решения

class Lamp {
    String model;
    boolean isOn;

    void turnOn() {
        isOn = true;
    }

    void turnOff() {
        isOn = false;
    }

    String status() {
        if (isOn) {
            return model + ": on";
        }
        return model + ": off";
    }
}
