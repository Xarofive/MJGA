import org.junit.FixMethodOrder;
import org.junit.Test;
import org.junit.runners.MethodSorters;

@FixMethodOrder(MethodSorters.NAME_ASCENDING)
public class Task3_6 {

    @Test
    public void test1_discountReturnsExpectedValues() {
        check(1000, 20, 800);
        check(500, 50, 250);
        check(750, 0, 750);
        check(200, 100, 0);
        check(999, 1, 990);
    }

    private void check(int price, int percent, int expected) {
        int actual = discount(price, percent);
        if (actual != expected) {
            failWithoutStackTrace("Тест не пройден: discount(" + price + ", " + percent +
                    ") должен вернуть " + expected + ", но вернул " + actual + ".");
        }
    }

    private void failWithoutStackTrace(String message) {
        AssertionError error = new AssertionError(message);
        error.setStackTrace(new StackTraceElement[0]);
        throw error;
    }

    //START_STUDENT_PLACEHOLDER//
    // Твой код
    //END_STUDENT_PLACEHOLDER//
}

// ожидаемый код решения

static int discount(int price, int percent) {
    int discountAmount = price * percent / 100;
    return price - discountAmount;
}
