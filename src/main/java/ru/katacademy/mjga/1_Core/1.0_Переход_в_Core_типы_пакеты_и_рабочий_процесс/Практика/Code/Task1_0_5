import org.junit.FixMethodOrder;
import org.junit.Test;
import org.junit.runners.MethodSorters;

@FixMethodOrder(MethodSorters.NAME_ASCENDING)
public class Task1_0_5 {

    @Test
    public void test1_returnsNextLatinLetter() {
        check('A', 'B');
        check('Y', 'Z');
        check('Z', 'A');
        check('7', '7');
        check('a', 'a');
    }

    private void check(char letter, char expected) {
        char actual = nextLatinLetter(letter);
        if (actual != expected) {
            failWithoutStackTrace("nextLatinLetter('" + letter + "') должен вернуть '" +
                    expected + "', но вернул '" + actual + "'.");
        }
    }

    private void failWithoutStackTrace(String message) {
        AssertionError error = new AssertionError(message);
        error.setStackTrace(new StackTraceElement[0]);
        throw error;
    }

