// ожидаемый код решения

static int countWordsLongerThan(String[] words, int minLength) {
    int count = 0;
    for (int i = 0; i < words.length; i++) {
        String word = words[i];
        if (word != null && word.length() > minLength) {
            count++;
        }
    }
    return count;
}
